# macOS
.DS_Store

# Local Claude Code config (personal, not project content)
.claude/

# BMAD installer-managed user prefs (regenerated on each install)
_bmad/config.user.toml

# BMAD framework installer scaffolding (regeneratable; not product)
_bmad/_config/
_bmad/bmm/
_bmad/core/
_bmad/scripts/
_bmad/config.toml

# BMAD planning + implementation artifacts — tracked in private planning repo
_bmad-output/

# Developer-side reference imagery (homage source photos; legal posture + not product)
faces/

# Xcode build artifacts
build/
DerivedData/
*.xcuserstate
xcuserdata/

# Generated Xcode project — regenerated from project.yml via `make project` (xcodegen)
Watches.xcodeproj/

# DMG build output (lives in dist/, populated by Story 3.5)
dist/

